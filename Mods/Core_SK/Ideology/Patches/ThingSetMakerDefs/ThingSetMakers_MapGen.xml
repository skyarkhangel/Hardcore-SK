            <fixedParams>
              <filter>
                <thingDefs>
                  <li>CupronickelAlloy</li>
				  <li>SteelBar</li>
				  <li>AlnicoAlloy</li>
				  <li>CarbonAlloy</li>
				  <li MayRequire="arpomo6.hmc.bizmat">Sarcasmium</li>
                </thingDefs>
              </filter>
              <countRange>17~78</countRange>
            </fixedParams>
          </thingSetMaker>
        </li>
		
		<!-- Some usefull industrial-level textiles -->
